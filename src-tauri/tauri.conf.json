{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tales Runner UMT Map Manager",
  "version": "0.1.0",
  "identifier": "com.talesrunner.umt-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tales Runner UMT Map Manager",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "copyright": "© 2026 Porygon",
    "category": "Utility",
    "shortDescription": "Tales Runner UMT Map Manager",
    "longDescription": "A desktop application for managing player-created maps (UMT) for Tales Runner. Install, deactivate, and manage your UMT maps easily."
  }
}
